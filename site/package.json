{
  "name": "ebay-summer-site",
  "version": "0.0.0",
  "description": "Landing page + changelog for the eBay Σummer extension (Vite + React, builds to ../docs)",
  "license": "GPL-3.0-or-later",
  "private": true,
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "prettier": "@lvucodes/ui/prettier",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . && stylelint \"src/**/*.css\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "presmoke": "npm run build",
    "smoke": "playwright test",
    "verify": "npm run lint && npm run format:check && npm run test:coverage && npm run build"
  },
  "dependencies": {
    "@lvucodes/ui": "^0.1.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.3.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "stylelint": "^17.14.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.7"
  }
}
